                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="24dp" android:background="#E5E7EB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:orientation="horizontal">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="▣" android:textColor="#9CA3AF" android:textSize="20sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Claimed" android:textColor="#6B7280" android:textSize="18sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="May 17, 03:45 PM" android:textColor="#000000" android:textSize="17sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:orientation="horizontal">
