                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="24dp" android:background="#E5E7EB" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:orientation="horizontal">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="🪙" android:textSize="18sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Points Used" android:textColor="#6B7280" android:textSize="18sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-100" android:textColor="#EF4444" android:textSize="17sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:orientation="horizontal">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="⌘" android:textColor="#000000" android:textSize="18sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Reference" android:textColor="#111827" android:textSize="16sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RWD-2026-001" android:textColor="#111827" android:textSize="16sp" />
