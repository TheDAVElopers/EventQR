                    </LinearLayout>
                    <TextView android:layout_width="52dp" android:layout_height="52dp" android:layout_gravity="end|center_vertical" android:background="@drawable/bg_circle_green" android:gravity="center" android:text="✓" android:textColor="#FFFFFF" android:textSize="34sp" android:textStyle="bold" />
                </FrameLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Coffee Voucher" android:textColor="#000000" android:textSize="23sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Spring Career Fair 2026" android:textColor="#6B7280" android:textSize="18sp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="24dp" android:background="#E5E7EB" />
