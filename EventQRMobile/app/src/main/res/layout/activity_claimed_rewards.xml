                    </LinearLayout>
                    <TextView android:layout_width="52dp" android:layout_height="52dp" android:layout_gravity="end|center_vertical" android:background="@drawable/bg_circle_green" android:gravity="center" android:text="✓" android:textColor="#FFFFFF" android:textSize="34sp" android:textStyle="bold" />
