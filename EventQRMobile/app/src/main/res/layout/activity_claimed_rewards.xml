                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="24dp" android:background="#E5E7EB" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="🪙    Points Used                                             -50" android:textColor="#EF4444" android:textSize="17sp" />
            </LinearLayout>
