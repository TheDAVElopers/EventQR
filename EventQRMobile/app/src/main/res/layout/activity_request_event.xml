<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="26dp"
        android:paddingTop="34dp"
        android:paddingBottom="30dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:gravity="center_vertical"
            android:text="‹  Request Event Creation"
            android:textColor="#000000"
            android:textSize="27sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="154dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:padding="20dp">

            <TextView android:layout_width="34dp" android:layout_height="match_parent" android:gravity="top|center_horizontal" android:text="ⓘ" android:textColor="#111111" android:textSize="23sp" />
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Request Organizer Access" android:textColor="#000000" android:textSize="18sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:lineSpacingExtra="6dp" android:text="Submit your event details to request organizer\nprivileges. Once approved by an admin, you'll\nbe able to create and manage your own events." android:textColor="#6B7280" android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Your Information" android:textColor="#000000" android:textSize="24sp" android:textStyle="bold" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="28dp" android:text="Full Name *" android:textColor="#000000" android:textSize="16sp" android:textStyle="bold" />
            <EditText android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="12dp" android:background="@drawable/bg_soft_input_no_stroke" android:hint="John Doe" android:paddingHorizontal="18dp" android:textColorHint="#8B8E98" android:textSize="18sp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="Email *" android:textColor="#000000" android:textSize="16sp" android:textStyle="bold" />
            <EditText android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="12dp" android:background="@drawable/bg_soft_input_no_stroke" android:hint="john.doe@example.com" android:inputType="textEmailAddress" android:paddingHorizontal="18dp" android:textColorHint="#8B8E98" android:textSize="18sp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="Phone Number *" android:textColor="#000000" android:textSize="16sp" android:textStyle="bold" />
            <EditText android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="12dp" android:background="@drawable/bg_soft_input_no_stroke" android:hint="+63 912 3456 789" android:inputType="phone" android:paddingHorizontal="18dp" android:textColorHint="#8B8E98" android:textSize="18sp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="Organization / Company *" android:textColor="#000000" android:textSize="16sp" android:textStyle="bold" />
            <EditText android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="12dp" android:background="@drawable/bg_soft_input_no_stroke" android:hint="Enter your organization name" android:paddingHorizontal="18dp" android:textColorHint="#6B7280" android:textSize="16sp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="Your Role *" android:textColor="#000000" android:textSize="16sp" android:textStyle="bold" />
            <EditText android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="12dp" android:background="@drawable/bg_soft_input_no_stroke" android:hint="e.g., Event Manager, Community Lead" android:paddingHorizontal="18dp" android:textColorHint="#6B7280" android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Proposed Event Details" android:textColor="#000000" android:textSize="20sp" android:textStyle="bold" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Event Title *" android:textColor="#000000" android:textSize="13sp" android:textStyle="bold" />
            <EditText android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="8dp" android:background="@drawable/bg_soft_input_no_stroke" android:hint="Enter event title" android:paddingHorizontal="14dp" android:textColorHint="#6B7280" android:textSize="14sp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Event Category *" android:textColor="#000000" android:textSize="13sp" android:textStyle="bold" />
            <EditText android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="8dp" android:background="@drawable/bg_soft_input_no_stroke" android:hint="e.g., Technology, Business, Education" android:paddingHorizontal="14dp" android:textColorHint="#6B7280" android:textSize="14sp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Event Description *" android:textColor="#000000" android:textSize="13sp" android:textStyle="bold" />
            <EditText android:layout_width="match_parent" android:layout_height="64dp" android:layout_marginTop="8dp" android:background="@drawable/bg_soft_input_no_stroke" android:gravity="top" android:hint="Provide a detailed description of your\nproposed event" android:inputType="textMultiLine" android:padding="14dp" android:textColorHint="#6B7280" android:textSize="14sp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Expected Attendees *" android:textColor="#000000" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="8dp" android:background="@drawable/bg_soft_input_no_stroke" android:hint="e.g., 100" android:inputType="number" android:paddingHorizontal="12dp" android:textColorHint="#6B7280" android:textSize="14sp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Planned Date *" android:textColor="#000000" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="8dp" android:background="@drawable/bg_soft_input_no_stroke" android:hint="dd/mm/yyyy" android:paddingHorizontal="12dp" android:textColorHint="#111111" android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Event Location *" android:textColor="#000000" android:textSize="13sp" android:textStyle="bold" />
            <EditText android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="8dp" android:background="@drawable/bg_soft_input_no_stroke" android:hint="Enter venue or address" android:paddingHorizontal="14dp" android:textColorHint="#6B7280" android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Experience &amp; Justification" android:textColor="#000000" android:textSize="24sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="Event Management Experience" android:textColor="#000000" android:textSize="16sp" android:textStyle="bold" />
            <EditText android:layout_width="match_parent" android:layout_height="86dp" android:layout_marginTop="10dp" android:background="@drawable/bg_soft_input_no_stroke" android:gravity="top" android:hint="Describe your previous event management\nexperience (optional)" android:inputType="textMultiLine" android:padding="16dp" android:textColorHint="#6B7280" android:textSize="16sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="Why do you want to organize this event? *" android:textColor="#000000" android:textSize="16sp" android:textStyle="bold" />
            <EditText android:layout_width="match_parent" android:layout_height="86dp" android:layout_marginTop="10dp" android:background="@drawable/bg_soft_input_no_stroke" android:gravity="top" android:hint="Explain your motivation and goals for this\nevent" android:inputType="textMultiLine" android:padding="16dp" android:textColorHint="#6B7280" android:textSize="16sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="Website / Social Media (Optional)" android:textColor="#000000" android:textSize="16sp" android:textStyle="bold" />
            <EditText android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="10dp" android:background="@drawable/bg_soft_input_no_stroke" android:hint="https://example.com" android:paddingHorizontal="16dp" android:textColorHint="#6B7280" android:textSize="16sp" />
        </LinearLayout>

        <CheckBox
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:buttonTint="#CBD5E1"
            android:lineSpacingExtra="6dp"
            android:text="I certify that the information provided is\naccurate and I understand that my request\nwill be reviewed by administrators. I agree to\ncomply with all platform terms and event\nmanagement guidelines."
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/button_rounded"
            android:enabled="false"
            android:text="Submit Request"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_logout_button"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
