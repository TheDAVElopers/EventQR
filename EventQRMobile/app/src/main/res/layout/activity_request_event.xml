<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/back_btn"
                android:layout_gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginRight="15dp"
                android:layout_marginLeft="5dp"
                android:padding="5dp"
                />

        <TextView
            android:id="@+id/backText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="Request Event Creation"
            android:textColor="#111827"
            android:textSize="24sp"
            android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Submit the event details for admin review."
            android:textColor="#6B7280"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/formMessageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_info_card"
            android:padding="12dp"
            android:textColor="#111827"
            android:textSize="14sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/successStateContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Request Submitted"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Your event request has been submitted for admin review."
                android:textColor="#4B5563"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/successStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Status: Pending"
                android:textColor="#25215F"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/successViewRequestsButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/button_rounded"
                android:text="View My Event Request"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/successDashboardButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_outline_button"
                android:text="Back to Dashboard"
                android:textAllCaps="false"
                android:textColor="#25215F"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Information"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView style="@style/RequestEventLabel" android:text="Event Name *" />
            <EditText
                android:id="@+id/eventNameInput"
                style="@style/RequestEventInput"
                android:hint="Event name" />

            <TextView style="@style/RequestEventLabel" android:text="Event Description *" />
            <EditText
                android:id="@+id/eventDescriptionInput"
                style="@style/RequestEventInput.Multi"
                android:hint="Describe the event"
                android:inputType="textMultiLine" />

            <TextView style="@style/RequestEventLabel" android:text="Event Category *" />
            <EditText
                android:id="@+id/eventCategoryInput"
                style="@style/RequestEventInput"
                android:hint="Technology, business, education" />

            <TextView style="@style/RequestEventLabel" android:text="Target Audience" />
            <EditText
                android:id="@+id/targetAudienceInput"
                style="@style/RequestEventInput"
                android:hint="Students, professionals, community members" />

            <TextView style="@style/RequestEventLabel" android:text="Expected Attendees / Capacity *" />
            <EditText
                android:id="@+id/capacityInput"
                style="@style/RequestEventInput"
                android:hint="100"
                android:inputType="number" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Schedule and Location"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView style="@style/RequestEventLabel" android:text="Venue / Location *" />
            <EditText
                android:id="@+id/venueInput"
                style="@style/RequestEventInput"
                android:hint="Venue or address" />

            <TextView style="@style/RequestEventLabel" android:text="Start Date and Time *" />
            <EditText
                android:id="@+id/startDateTimeInput"
                style="@style/RequestEventInput"
                android:hint="Tap to select date and time"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:inputType="none"
                android:longClickable="false"
                android:textIsSelectable="false" />

            <TextView style="@style/RequestEventLabel" android:text="End Date and Time *" />
            <EditText
                android:id="@+id/endDateTimeInput"
                style="@style/RequestEventInput"
                android:hint="Tap to select date and time"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:inputType="none"
                android:longClickable="false"
                android:textIsSelectable="false" />

            <TextView style="@style/RequestEventLabel" android:text="Registration Start Date" />
            <EditText
                android:id="@+id/registrationStartDateTimeInput"
                style="@style/RequestEventInput"
                android:hint="Tap to select date and time"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:inputType="none"
                android:longClickable="false"
                android:textIsSelectable="false" />

            <TextView style="@style/RequestEventLabel" android:text="Registration End Date" />
            <EditText
                android:id="@+id/registrationEndDateTimeInput"
                style="@style/RequestEventInput"
                android:hint="Tap to select date and time"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:inputType="none"
                android:longClickable="false"
                android:textIsSelectable="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Requester Information"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView style="@style/RequestEventLabel" android:text="Requester Name *" />
            <EditText
                android:id="@+id/requesterNameInput"
                style="@style/RequestEventInput"
                android:hint="Full name" />

            <TextView style="@style/RequestEventLabel" android:text="Contact Email *" />
            <EditText
                android:id="@+id/contactEmailInput"
                style="@style/RequestEventInput"
                android:hint="name@example.com"
                android:inputType="textEmailAddress" />

            <TextView style="@style/RequestEventLabel" android:text="Contact Number *" />
            <EditText
                android:id="@+id/contactNumberInput"
                style="@style/RequestEventInput"
                android:hint="+63 912 345 6789"
                android:inputType="phone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Setup"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView style="@style/RequestEventLabel" android:text="Requested Features" />

            <CheckBox android:id="@+id/featureQrRegistration" style="@style/RequestEventCheckbox" android:text="QR registration" />
            <CheckBox android:id="@+id/featureQrCheckIn" style="@style/RequestEventCheckbox" android:text="QR check-in / entry logging" />
            <CheckBox android:id="@+id/featureAttendanceTracking" style="@style/RequestEventCheckbox" android:text="Attendance tracking" />
            <CheckBox android:id="@+id/featureBenefitClaiming" style="@style/RequestEventCheckbox" android:text="Benefit claiming" />
            <CheckBox android:id="@+id/featureBoothTracking" style="@style/RequestEventCheckbox" android:text="Booth/session tracking" />
            <CheckBox android:id="@+id/featureRewardsPoints" style="@style/RequestEventCheckbox" android:text="Rewards and points" />
            <CheckBox android:id="@+id/featureIdPrinting" style="@style/RequestEventCheckbox" android:text="ID printing" />

            <TextView style="@style/RequestEventLabel" android:text="Event Poster / Logo" />
            <EditText
                android:id="@+id/eventLogoInput"
                style="@style/RequestEventInput"
                android:hint="Optional image URL"
                android:inputType="textUri" />

            <TextView style="@style/RequestEventLabel" android:text="Additional Notes" />
            <EditText
                android:id="@+id/additionalNotesInput"
                style="@style/RequestEventInput.Multi"
                android:hint="Anything else admins should know"
                android:inputType="textMultiLine" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reason for Request"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView style="@style/RequestEventLabel" android:text="Reason for Request *" />
            <EditText
                android:id="@+id/reasonForRequestInput"
                style="@style/RequestEventInput.Multi"
                android:hint="Why should this event be created?"
                android:inputType="textMultiLine" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/submitProgress"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/submitRequestButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/button_rounded"
            android:text="Submit Request"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/cancelButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_logout_button"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />
    </LinearLayout>
</ScrollView>
