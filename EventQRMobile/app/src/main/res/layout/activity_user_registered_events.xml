<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/eventqr_bg">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/eventqr_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="My Registered Events"
            android:textColor="@color/eventqr_text"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:id="@+id/topDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/eventqr_border"
        android:alpha="0.5"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar" />

    <!-- Filter Section -->
    <LinearLayout
        android:id="@+id/layoutFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/topDivider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="@color/eventqr_muted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Filter by Status"
                android:textColor="@color/eventqr_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="start|center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_nav_active"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="All"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipRegistered"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_soft_input_no_stroke"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="Registered"
                android:textColor="@color/eventqr_muted" />

            <TextView
                android:id="@+id/chipCompleted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_soft_input_no_stroke"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="Completed"
                android:textColor="@color/eventqr_muted" />

        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/filterDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/eventqr_border"
        android:alpha="0.3"
        app:layout_constraintTop_toBottomOf="@id/layoutFilter" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRegisteredEvents"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filterDivider"
        tools:listitem="@layout/item_registered_event" />

    <TextView
        android:id="@+id/txtRegisteredEventsEmpty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="No registered events yet."
        android:textColor="@color/eventqr_muted"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/recyclerRegisteredEvents"
        app:layout_constraintEnd_toEndOf="@id/recyclerRegisteredEvents"
        app:layout_constraintStart_toStartOf="@id/recyclerRegisteredEvents"
        app:layout_constraintTop_toTopOf="@id/recyclerRegisteredEvents" />

</androidx.constraintlayout.widget.ConstraintLayout>
