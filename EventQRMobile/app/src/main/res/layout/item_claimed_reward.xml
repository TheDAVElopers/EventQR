<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtClaimedCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_purple_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Category"
            android:textColor="#7C3AED"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtClaimedStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_green_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Redeemed"
            android:textColor="#166534"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtClaimedTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Reward Title"
        android:textColor="@color/eventqr_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtClaimedDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Details"
        android:textColor="@color/eventqr_muted"
        android:textSize="14sp" />

</LinearLayout>
