<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.EventQR" parent="Theme.MaterialComponents.Light.NoActionBar.Bridge">
        <item name="android:windowAnimationStyle">@style/NoAnimation</item>
        <item name="colorPrimary">@color/eventqr_indigo</item>
        <item name="colorSecondary">@color/eventqr_purple</item>
    </style>

    <style name="NoAnimation">
        <item name="android:activityOpenEnterAnimation">@null</item>
        <item name="android:activityOpenExitAnimation">@null</item>
        <item name="android:activityCloseEnterAnimation">@null</item>
        <item name="android:activityCloseExitAnimation">@null</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_transparent_icon</item>
        <item name="windowSplashScreenBackground">@color/eventqr_indigo</item>
        <item name="postSplashScreenTheme">@style/Theme.EventQR</item>
    </style>

    <style name="RequestEventLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:textColor">#111827</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RequestEventInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/bg_soft_input_no_stroke</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:textColor">#111827</item>
        <item name="android:textColorHint">#8B8E98</item>
        <item name="android:textSize">15sp</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="RequestEventInput.Multi" parent="RequestEventInput">
        <item name="android:layout_height">96dp</item>
        <item name="android:gravity">top</item>
        <item name="android:padding">14dp</item>
        <item name="android:singleLine">false</item>
        <item name="android:minLines">3</item>
    </style>

    <style name="RequestEventCheckbox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingVertical">2dp</item>
        <item name="android:textColor">#111827</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
